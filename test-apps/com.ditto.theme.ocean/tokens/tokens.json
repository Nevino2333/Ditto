{
  "colors": {
    "primary": "#0077b6",
    "primaryLight": "#0096c7",
    "primaryDark": "#005f8a",
    "background": "#023e8a",
    "surface": "#03045e",
    "surfaceRaised": "#0077b6",
    "textPrimary": "#caf0f8",
    "textSecondary": "#90e0ef",
    "textDisabled": "#48bfe3",
    "border": "#0077b6",
    "borderSubtle": "#005f8a",
    "accent": "#00b4d8",
    "success": "#06d6a0",
    "warning": "#ffd166",
    "error": "#ef476f",
    "info": "#00b4d8"
  },
  "typography": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "monoFontFamily": "'Consolas', 'Fira Code', 'JetBrains Mono', monospace",
    "fontSize": { "xs": "11px", "sm": "12px", "base": "14px", "lg": "16px", "xl": "18px", "2xl": "22px" },
    "fontWeight": { "normal": "400", "medium": "500", "semibold": "600", "bold": "700" }
  },
  "spacing": { "xs": "4px", "sm": "8px", "md": "12px", "lg": "16px", "xl": "24px", "2xl": "32px" },
  "radius": { "sm": "4px", "md": "8px", "lg": "12px", "xl": "16px", "full": "9999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.4)",
    "md": "0 2px 8px rgba(0,0,0,0.5)",
    "lg": "0 4px 16px rgba(0,0,0,0.6)"
  },
  "animation": {
    "duration": "0.15s",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
