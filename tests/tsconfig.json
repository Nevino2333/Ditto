{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@ditto/shared": ["../packages/shared/src"],
      "@ditto/packager": ["../packages/packager/src"]
    }
  },
  "include": ["./**/*.ts"]
}
